{
  "version": "2.0",
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  },
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    },
    "logLevel": {
      "default": "None",
      "Host.Singleton": "None",
      "Host.Aggregator": "Warning",
      "Host.Results": "None",
      "Host.Triggers.Blobs": "None",
      "Host.Triggers.Queues": "None",
      "Host.Triggers.ServiceBus": "None",
      "Azure.Core": "None",
      "Azure.Storage": "None",
      "Azure.Storage.Blobs": "None",
      "Azure.Messaging.ServiceBus": "None",
      "Microsoft.Azure.WebJobs.Extensions.ServiceBus": "None",
      "Microsoft.Azure.WebJobs.Host.Singleton": "None",
      "Function.chat": "Warning"
    }
  },
  "cors": {
    "allowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173",
      "http://localhost:5174",
      "http://127.0.0.1:5174"
    ],
    "supportCredentials": false
  }
}
