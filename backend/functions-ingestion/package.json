{
  "name": "functions-ingestion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/src/app.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "search:clear": "node scripts/clear-search-index.mjs",
    "search:debug:rebuild": "node scripts/rebuild-debug-search-index.mjs",
    "storage:setup": "node scripts/init-local-storage.mjs",
    "e2e:upload": "bash scripts/e2e-upload-check.sh",
    "start": "FUNCTIONS_WORKER_RUNTIME=node func start",
    "start:7072": "FUNCTIONS_WORKER_RUNTIME=node func start --port 7072",
    "start:verbose": "FUNCTIONS_WORKER_RUNTIME=node func start --verbose",
    "start:build": "npm run build && FUNCTIONS_WORKER_RUNTIME=node func start"
  },
  "dependencies": {
    "@azure/cosmos": "^4.5.0",
    "@azure/functions": "^4.5.0",
    "@azure/search-documents": "^12.1.0",
    "@azure/storage-blob": "^12.25.0",
    "jimp": "^1.6.1",
    "openai": "^6.34.0",
    "pdf-parse": "^1.1.1",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3"
  }
}
