# Defaults to `/api` when empty.
# - Local dev: Vite proxy can forward `/api` to Functions host.
# - Azure: set to https://<function-app>.azurewebsites.net/api when frontend and API are on different hosts.
VITE_UPLOAD_API_BASE_URL=
# Preferred explicit Node backend URL (Functions). Falls back to VITE_UPLOAD_API_BASE_URL.
VITE_NODE_API_BASE_URL=
# Optional Python backend URL (Web App / Container App). If empty, Node URL is reused.
VITE_PYTHON_API_BASE_URL=
# Which backend is selected at first render: node | python (default: node)
VITE_DEFAULT_BACKEND=node
# Optional alias for compatibility with CI variables. If both are set, VITE_UPLOAD_API_BASE_URL wins.
VITE_API_BASE_URL=
# For upload/chat APIs with authLevel=function. Sent as x-functions-key.
# - Azure: Portal → Function App → App keys → _default
# - Local: Core Tools 4.9 has no `func keys list` → use VS Code Azure Functions “Copy Function Url” for the code= value, or a deployed app key from Portal
# Catalog/purge (/documents/catalog, /purge) work without a key in this demo.
VITE_UPLOAD_API_KEY=
# Optional explicit key aliases (Node key falls back to VITE_UPLOAD_API_KEY, Python has no default).
VITE_NODE_API_KEY=
VITE_PYTHON_API_KEY=
# Default tenant when the UI field is empty. Align with Functions ALLOWED_TENANT_IDS in deployment.
VITE_TENANT_ID=tenant-a
