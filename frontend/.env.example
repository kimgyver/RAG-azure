VITE_UPLOAD_API_BASE_URL=http://localhost:7071/api
# 업로드·챗 등 authLevel=function 인 API용. x-functions-key 헤더로 전달된다.
# - Azure 배포: Portal → Function App →「앱 키」→ _default
# - 로컬: Core Tools 4.9에는 `func keys list` 없음 → VS Code Azure Functions 확장에서 HTTP 함수「Copy Function Url」로 code= 값 확인, 또는 배포 앱 Portal 키 사용
# 문서 목록·삭제(/documents/catalog, /purge)는 키 없이도 호출 가능(데모용).
VITE_UPLOAD_API_KEY=
# 기본 tenant (UI 입력이 비어 있을 때 사용). 배포 시 Functions의 ALLOWED_TENANT_IDS와 맞출 것.
VITE_TENANT_ID=tenant-a
