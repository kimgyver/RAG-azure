# This repo does NOT ship terraform.tfvars (secrets + machine-specific).
# Create it yourself — same folder as this file, name exactly: terraform.tfvars
#
#   cd infra && cp terraform.tfvars.example terraform.tfvars
#   # then uncomment/edit lines you need
#
# Copy to terraform.tfvars (gitignored).
#
# --- REQUIRED when Azure returns "Basic VMs: 0" / "Dynamic VMs: 0" on plan create ---
# Point to an EXISTING Linux App Service plan in THIS subscription (Portal → plan → Resource ID):
# existing_linux_service_plan_resource_id = "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Web/serverFarms/<planName>"
#
# location   = "eastus"
# project_name = "ragapp"
# name_suffix = "prod01"  # optional fixed suffix (letters/digits). Example names: ragapp-prod01-fn / ragapp-prod01-swa
# app_service_plan_sku = "Y1"   # only if Terraform creates the plan AND you have Consumption quota
# static_web_app_sku_tier = "Free"      # keep Free plan by default
# static_web_app_sku_size = "Free"
# If Terraform fails with "too many static sites with SKU: Free", delete unused Free SWAs in this subscription,
# then re-run apply (or temporarily switch both values to Standard).
# static_web_app_origin = "https://<your-app>.azurestaticapps.net"  # optional; add after SWA is created
# blob_cors_origins = ["http://localhost:5173", "https://your-frontend.azurestaticapps.net"]
# extra_app_settings = {
#   BLOB_TRIGGER_SOURCE = "EventGrid"
# }
# allowed_tenant_ids = ["tenant-a", "tenant-b"]
# enable_chat_alerts = true
# chat_alert_email_receivers = ["ops@example.com"]
# chat_failure_count_threshold = 3
# chat_latency_p95_threshold_ms = 6000
#
# --- Optional: merge into Function App settings (overrides defaults in main.tf) ---
# Do NOT commit real secrets. Use Portal Configuration instead if you prefer.
#
# extra_app_settings = {
#   # --- Azure AI Search (existing service is fine; no need to create a second one) ---
#   SEARCH_ENABLED   = "true"
#   SEARCH_ENDPOINT  = "https://<your-search-service>.search.windows.net"
#   SEARCH_API_KEY   = "<admin-key-from-portal-keys-blade>"
#   # SEARCH_INDEX_NAME = "rag-chunks"   # omit unless you use a non-default index name
#
#   # --- Cosmos DB metadata (optional; catalog merges Cosmos + Search when both on) ---
#   # COSMOS_DB_ENABLED = "true"
#   # COSMOS_ENDPOINT   = "https://<account>.documents.azure.com:443/"
#   # COSMOS_KEY        = "<key>"
#
#   # --- OpenAI / Azure OpenAI (chat, embeddings when EMBEDDING_ENABLED=true) ---
#   # OPENAI_API_KEY = "sk-..."
#   # AZURE_OPENAI_ENDPOINT = "https://<resource>.openai.azure.com/"
#   # AZURE_OPENAI_API_KEY    = "..."
#
#   # --- Chat cost guardrails (optional overrides) ---
#   # CHAT_PROMPT_CHAR_BUDGET = "12000"
#   # CHAT_MAX_COMPLETION_TOKENS = "600"
#   # CHAT_MEMORY_RECENT_TURNS = "3"
# }
